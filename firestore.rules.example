rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isRootSuperadmin() {
      return isSignedIn() && request.auth.token.email == 'adm@acs.com';
    }

    function userDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function userEmpresaId() {
      return userDoc().data.empresaId;
    }

    function hasEmpresaScope() {
      return userEmpresaId() != null && userEmpresaId() != '';
    }

    function sameEmpresa(resourceData) {
      return isSignedIn() && resourceData.empresaId == userEmpresaId();
    }

    function sameEmpresaOnCreate() {
      return isSignedIn() && request.resource.data.empresaId == userEmpresaId();
    }

    function canAccessScopedCollection(resourceData) {
      return isSignedIn() && (
        !hasEmpresaScope()
        || sameEmpresa(resourceData)
      );
    }

    function canCreateScopedCollection() {
      return isSignedIn() && (
        !hasEmpresaScope()
        || sameEmpresaOnCreate()
      );
    }

    match /usuarios/{userId} {
      allow read: if isRootSuperadmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isRootSuperadmin();
      allow update: if isRootSuperadmin();
      allow delete: if isRootSuperadmin();
    }

    match /empresas/{empresaId} {
      allow read, write: if isRootSuperadmin();
    }

    match /logsUso/{logId} {
      allow read, write: if isRootSuperadmin();
    }

    match /resumos/{resumoId} {
      allow read: if isSignedIn();
      allow write: if isRootSuperadmin();
    }

    match /{collectionName}/{docId} {
      allow read: if isRootSuperadmin()
        || (
          canAccessScopedCollection(resource.data)
          && collectionName in ['clientes', 'terminais', 'embarcacoes', 'rotasValores', 'encomendas', 'movimentacoes', 'caixa']
        );

      allow create: if isRootSuperadmin()
        || (
          canCreateScopedCollection()
          && collectionName in ['clientes', 'terminais', 'embarcacoes', 'rotasValores', 'encomendas', 'movimentacoes', 'caixa']
        );

      allow update: if isRootSuperadmin()
        || (
          canAccessScopedCollection(resource.data)
          && collectionName in ['clientes', 'terminais', 'embarcacoes', 'rotasValores', 'encomendas', 'movimentacoes', 'caixa']
          && (
            !hasEmpresaScope()
            || request.resource.data.empresaId == resource.data.empresaId
          )
        );

      allow delete: if isRootSuperadmin()
        || (
          canAccessScopedCollection(resource.data)
          && collectionName in ['clientes', 'terminais', 'embarcacoes', 'rotasValores', 'encomendas', 'movimentacoes', 'caixa']
        );
    }
  }
}
